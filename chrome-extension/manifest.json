{
  "manifest_version": 3,
  "name": "多网站自动签到助手",
  "version": "1.1.0",
  "description": "基于 linux.do OAuth2.0 授权的多网站自动签到工具",
  "permissions": [
    "cookies",
    "storage",
    "alarms",
    "scripting",
    "tabs",
    "webRequest"
  ],
  "host_permissions": [
    "https://*/*"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
